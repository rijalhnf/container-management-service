{
  "info": {
    "name": "Product API — Auth + CRUD",
    "description": "Collection for the Go Gin Product API with JWT Auth, Middleware & CORS.\n\n**Flow:**\n1. Register → Login (token auto-saved) → Use protected routes\n\nBase URL: `http://localhost:8888`",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8888",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string",
      "description": "Auto-populated by the Login request"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/health",
            "description": "Public — no auth required"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/register",
            "description": "Public — create a new user account.\n\nPassword must be at least 6 characters.",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"secret123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": []
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.token) {",
                  "    pm.collectionVariables.set('token', json.token);",
                  "    console.log('Token saved:', json.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/login",
            "description": "Public — authenticate and receive a JWT token.\n\nThe token is **automatically saved** to the `token` collection variable and used in all protected requests.",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"secret123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": []
        },
        {
          "name": "Me (whoami)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/auth/me",
            "description": "🔒 Protected — returns the currently authenticated user's info from the JWT claims.",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "Get All Products",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/products",
            "description": "🔒 Protected — returns all products.",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Product by ID",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/products/1",
            "description": "🔒 Protected — returns a single product by ID. Change `1` to a valid product ID.",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Create Product (single)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/products",
            "description": "🔒 Protected — creates a single product.",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Laptop Pro\",\n  \"price\": 1299,\n  \"stock\": 50\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": []
        },
        {
          "name": "Create Products (batch)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/products",
            "description": "🔒 Protected — creates multiple products in a single request by sending an array.",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "[\n  { \"name\": \"Keyboard\", \"price\": 89, \"stock\": 200 },\n  { \"name\": \"Mouse\", \"price\": 45, \"stock\": 300 },\n  { \"name\": \"Monitor\", \"price\": 399, \"stock\": 75 }\n]",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": []
        },
        {
          "name": "Update Product",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/api/products/1",
            "description": "🔒 Protected — updates a product by ID. Change `1` to a valid product ID.",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Laptop Pro Max\",\n  \"price\": 1499,\n  \"stock\": 30\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": []
        },
        {
          "name": "Delete Product",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/api/products/1",
            "description": "🔒 Protected — deletes a product by ID. Change `1` to a valid product ID.",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Auth Errors (negative tests)",
      "item": [
        {
          "name": "No Token → 401",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/products",
            "description": "Expected: 401 — \"Authorization header is required\""
          },
          "response": []
        },
        {
          "name": "Invalid Token → 401",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/products",
            "description": "Expected: 401 — \"Invalid or expired token\"",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "this.is.not.a.valid.token",
                  "type": "string"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Duplicate Register → 409",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/register",
            "description": "Expected: 409 — \"Email is already registered\" (run Register first)",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"secret123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": []
        },
        {
          "name": "Wrong Password → 401",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/auth/login",
            "description": "Expected: 401 — \"Invalid email or password\"",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"wrongpassword\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": []
        }
      ]
    }
  ]
}
